];
let twLine=0,twChar=0,twInit=false,twInt=null;

function startTypewriter(){
  if(twInit)return;twInit=true;
  const box=document.getElementById('twText');
  twInt=setInterval(()=>{
    if(twLine>=lines.length){
      clearInterval(twInt);
      document.getElementById('twNext').classList.add('show');
      return;
    }
    if(twChar===0){
      const p=document.createElement('p');
      p.style.cssText='font-family:"Cormorant Garamond",serif;font-size:18px;font-weight:300;line-height:1.9;margin-bottom:10px;opacity:0;transition:opacity .4s';
      box.insertBefore(p,box.querySelector('.tw-cursor'));
      setTimeout(()=>p.style.opacity='1',30);
    }
    const p=box.querySelector('p:last-of-type');
    const line=lines[twLine];
    if(p&&twChar<line.length){p.textContent=line.slice(0,++twChar)}
    else{twChar=0;twLine++}
  },26);
}

