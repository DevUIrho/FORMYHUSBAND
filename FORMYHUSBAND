// ══ S5 GARDEN ══
const gc=document.getElementById('gardenCanvas');
const gx=gc.getContext('2d');
let gFlowers=[],gInited=false;
const gPromises=['I\'ll listen more','I\'ll be kinder','I\'ll show up','I\'ll be patient','I won\'t run','I\'ll try harder','I\'ll be honest','I\'ll stay','I\'ll care more','I\'ll be gentler'];
let gIdx=0;

function initGarden(){
  if(gInited)return;gInited=true;
  drawGround();
  gc.addEventListener('click',e=>{
    const r=gc.getBoundingClientRect();
    const sx=gc.width/r.width,sy=gc.height/r.height;
    const x=(e.clientX-r.left)*sx,y=(e.clientY-r.top)*sy;
    plantFlower(x,Math.min(y,210));
  });
}

function drawGround(){
  gx.clearRect(0,0,440,240);
  const sky=gx.createLinearGradient(0,0,0,190);
  sky.addColorStop(0,'#dff0e5');sky.addColorStop(1,'#f5faf7');
  gx.fillStyle=sky;gx.fillRect(0,0,440,190);
  const grd=gx.createLinearGradient(0,190,0,240);
  grd.addColorStop(0,'#7aab8a');grd.addColorStop(1,'#4a7c59');
  gx.fillStyle=grd;gx.fillRect(0,190,440,50);
  for(let i=0;i<9;i++){
    gx.strokeStyle='rgba(74,124,89,0.25)';gx.lineWidth=1;
    gx.beginPath();gx.moveTo(i*50,190);
    gx.bezierCurveTo(i*50+8,198,i*50+32,194,i*50+50,190);gx.stroke();
  }
  gFlowers.forEach(f=>drawGF(f));
}

function plantFlower(x,y){
  const promise=gPromises[gIdx%gPromises.length];gIdx++;
  const f={x,y,promise,hue:95+Math.random()*50,s:0,anim:true};
  gFlowers.push(f);
  let t=0;
  const iv=setInterval(()=>{t+=.04;f.s=Math.min(t,1);drawGround();if(t>=1){f.anim=false;clearInterval(iv)}},16);
  const n=gFlowers.length;
  document.getElementById('gardenHint').textContent=`🌱 ${n} promise${n!==1?'s':''} planted${n>=5?' — that\'s enough to grow something beautiful 💚':''}`;
  if(n>=5)setTimeout(()=>goTo(5),1100);
}

function drawGF(f){
  const {x,y,hue,s,promise}=f;
  if(s<=0)return;
  gx.save();gx.translate(x,y);gx.scale(s,s);
  gx.strokeStyle=`hsl(${hue},45%,32%)`;gx.lineWidth=2;
  gx.beginPath();gx.moveTo(0,0);gx.lineTo(0,28);gx.stroke();
  for(let i=0;i<6;i++){
    const a=(i/6)*Math.PI*2;
    gx.beginPath();
    gx.ellipse(Math.cos(a)*9,Math.sin(a)*9-10,6,10,a,0,Math.PI*2);
    gx.fillStyle=`hsla(${hue},48%,72%,0.88)`;gx.fill();
  }
  gx.beginPath();gx.arc(0,-10,7,0,Math.PI*2);
  gx.fillStyle=`hsl(${hue},58%,52%)`;gx.fill();
  gx.restore();
  if(s>=0.75){
    gx.save();gx.globalAlpha=s;
    gx.font='bold 8.5px DM Sans';gx.fillStyle='rgba(46,61,53,0.75)';
    gx.textAlign='center';gx.textBaseline='bottom';
    gx.fillText(promise,x,y-26);gx.restore();
  }
}

